{
  "name": "site",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc -b && vite build",
    "build:pages": "vue-tsc -b && vite build --base=/TopVenuePapers/",
    "preview": "vite preview",
    "papers:ingest:iclr": "node scripts/ingest-openreview.mjs --limit 500 --max-pages 6 --out data/openreview/iclr-2026-candidates.json",
    "papers:ingest:ccfa": "node scripts/ingest-ccfa-2026.mjs",
    "papers:generate": "node scripts/generate-paper-intros.mjs --input data/openreview/iclr-2026-candidates.json --out data/papers.generated.json",
    "papers:generate:local": "node scripts/generate-local-guides.mjs --input data/openreview/iclr-2026-candidates.json --count 100 --out data/papers.generated.json",
    "papers:validate": "node scripts/validate-papers.mjs --input public/data/papers.catalog.json --require-records --strict",
    "catalog:shards": "node scripts/build-catalog-shards.mjs",
    "semantic:build": "node scripts/semantic/build-embeddings.mjs --model Xenova/all-MiniLM-L6-v2",
    "semantic:build:mirror": "node scripts/semantic/build-embeddings.mjs --model Xenova/all-MiniLM-L6-v2 --remote-host https://hf-mirror.com",
    "semantic:sync-public": "node scripts/sync-semantic-public.mjs",
    "semantic:serve": "node scripts/semantic/semantic-server.mjs --model Xenova/all-MiniLM-L6-v2",
    "semantic:serve:mirror": "node scripts/semantic/semantic-server.mjs --model Xenova/all-MiniLM-L6-v2 --remote-host https://hf-mirror.com",
    "deploy:serve": "node scripts/semantic/serve-app.mjs --host 0.0.0.0 --port 4174 --model Xenova/all-MiniLM-L6-v2 --remote-host https://hf-mirror.com"
  },
  "dependencies": {
    "@huggingface/transformers": "^3.8.1",
    "fuse.js": "^7.3.0",
    "vue": "^3.5.32"
  },
  "devDependencies": {
    "@types/node": "^24.12.2",
    "@vitejs/plugin-vue": "^6.0.6",
    "@vue/tsconfig": "^0.9.1",
    "typescript": "~6.0.2",
    "vite": "^8.0.10",
    "vue-tsc": "^3.2.7"
  }
}
